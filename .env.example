# TempMail Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Neon PostgreSQL Connection
# ============================================
# Get these from your Neon dashboard: https://neon.tech
DB_HOST=ep-xxx.aws.neon.tech
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=neondb
DB_PORT=5432
DB_SSLMODE=require

# ============================================
# OPTIONAL - Application Settings
# ============================================

# Mail domain for SMTP (default: xelio.me)
MAIL_DOMAIN=xelio.me

# SMTP port to bind (default: 25)
# For local dev, use 1025 to avoid port permission issues
SMTP_PORT=25

# HTTP port (default: 3000)
HTTP_PORT=3000

# Rust log level (default: info)
RUST_LOG=info
